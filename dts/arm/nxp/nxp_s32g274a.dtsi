		lpe_lpi2c: i2c@42178000 {
			compatible = "nxp,lpi2c";
			reg = <0x42178000 0x4000>;
			clocks = <&clock NXP_S32_LPE_LPI2C_CLK>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		lpi2c0: i2c@400d4000 {
			compatible = "nxp,lpi2c";
			reg = <0x400d4000 0x4000>;
			clocks = <&clock NXP_S32_LPI2C0_CLK>;
			#address-cells = <1>;
			#size-cells = <0>;
			status = "disabled";
		};

		lpi2c1: i2c@406bc000 {
