			clocks = <&clock NXP_S32_FLEXCAN4_PE_NOGATE_CLK>;
			number-of-mb = <96>;
			number-of-mb-fd = <21>;
			interrupt-names = "ored", "ored_0_96_mb";
			status = "disabled";
		};

