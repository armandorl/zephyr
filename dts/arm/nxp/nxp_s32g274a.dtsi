			status = "disabled";
		};

		lpe_ftm: ftm@42158000 {
			compatible = "nxp,ftm-pwm";
			reg = <0x42158000 0x4000>;
			clocks = <&clock NXP_S32_LPE_FTM_IPG_CLK>;
			prescaler = <1>;
			#pwm-cells = <3>;
			status = "disabled";
		};

		lpe_swt: watchdog@4207c000 {
			compatible = "nxp,s32-swt";
			reg = <0x4207c000 0x4000>;
			clocks = <&clock NXP_S32_SAFE_CLK>;
			service-mode = "fixed";
			status = "disabled";
